// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int               @id @default(autoincrement())
  username           String            @unique
  email              String            @unique
  password           String
  city               String?
  region             String?
  name               String
  avatar             String            @default("/assets/avatar_default.svg")
  level              Int               @default(1)
  xp                 Int               @default(0)
  coins              Int               @default(0)
  rank               String            @default("mandrivnyk")
  unlockedItems      String            @default("[]") // JSON array of purchased cosmetic ids
  currentDestination String?
  // Live-GPS privacy toggle: when false, friends never see this user's dot.
  locationVisible    Boolean           @default(true)
  createdAt          DateTime          @default(now())
  achievements       UserAchievement[]
  transactions       CoinTransaction[]
  checkmarks         Checkmark[]

  sentFriendRequests     Friend[]  @relation("FriendSender")
  receivedFriendRequests Friend[]  @relation("FriendReceiver")
  sentMessages           Message[] @relation("MessageSender")
  receivedMessages       Message[] @relation("MessageReceiver")
}

// A friendship edge. One row per pair: sender is who initiated the request.
// SQLite has no enums, so status is a constrained string:
// PENDING | ACCEPTED | DECLINED.
model Friend {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())

  sender   User @relation("FriendSender", fields: [senderId], references: [id])
  receiver User @relation("FriendReceiver", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId, status])
}

// A direct chat message between two friends. readAt is null until the
// recipient opens the thread (read receipts).
model Message {
  id         Int       @id @default(autoincrement())
  senderId   Int
  receiverId Int
  text       String
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  sender   User @relation("MessageSender", fields: [senderId], references: [id])
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id])

  @@index([senderId, receiverId, id])
  @@index([receiverId, readAt])
}

model CoinTransaction {
  id        Int      @id @default(autoincrement())
  userId    Int
  amount    Int // signed: + earn, - spend
  reason    String // 'profile_complete' | 'achievement:<id>' | 'purchase:<itemId>' | ...
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Destination {
  id          Int     @id @default(autoincrement())
  name        String
  category    String
  image       String
  verified    Boolean @default(false)
  xpReward    Int     @default(100)
}

model Achievement {
  id          Int               @id @default(autoincrement())
  title       String
  description String
  xpReward    Int               @default(200)
  icon        String
  users       UserAchievement[]
}

model UserAchievement {
  userId        Int
  achievementId Int
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@id([userId, achievementId])
}

// Admin account for the moderation panel. There is always exactly one super
// admin (isSuper) whose login/password come from env and are re-synced on boot;
// it cannot be deleted. Super admins and regular admins can create more admins.
model Admin {
  id        Int      @id @default(autoincrement())
  login     String   @unique
  password  String // bcrypt hash
  name      String   @default("Адміністратор")
  isSuper   Boolean  @default(false)
  createdBy String?
  createdAt DateTime @default(now())
}

// A place on the explore map. Covers both admin-curated entries and
// user-submitted ones that must pass AI moderation before going public.
model Place {
  id          Int    @id @default(autoincrement())
  name        String
  region      String
  category    String // nature | mountains | history | city | coast
  description String
  bestSeason  String @default("Будь-коли")

  // Geolocation is mandatory — real WGS84 coordinates.
  lat Float
  lng Float

  // JSON array of image data URLs. At least 2 are required on submission.
  photos String @default("[]")

  // Exploration difficulty, 1 (easy) – 4 (extreme). Drives the XP reward.
  difficulty Int @default(1)

  status      String  @default("pending") // pending | approved | rejected
  source      String  @default("user") // user | admin
  submittedBy String? // display name / email of the submitter

  // AI moderation verdict.
  aiDecision String? // approve | reject | review
  aiReason   String?
  aiScore    Float?

  createdAt  DateTime  @default(now())
  reviewedAt DateTime?

  checkmarks Checkmark[]

  @@index([status])
}

// A verified visit: the user came to a Place, photographed it, and the AI
// (or the offline fallback) confirmed the visit. XP/coins are awarded once.
model Checkmark {
  id             Int      @id @default(autoincrement())
  userId         Int
  placeId        Int
  photo          String // data URL of the photo the user took at the point
  distanceMeters Float // distance from the point when the photo was taken
  aiVerified     Boolean
  aiReason       String?
  xpAwarded      Int
  createdAt      DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  place Place @relation(fields: [placeId], references: [id])

  // A place can be counted for a user only once.
  @@unique([userId, placeId])
}
