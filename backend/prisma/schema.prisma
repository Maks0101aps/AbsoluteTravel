// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int               @id @default(autoincrement())
  username           String            @unique
  email              String            @unique
  password           String
  city               String?
  region             String?
  name               String
  avatar             String            @default("/assets/avatar_default.avif")
  level              Int               @default(1)
  xp                 Int               @default(0)
  coins              Int               @default(0)
  rank               String            @default("mandrivnyk")
  unlockedItems      String            @default("[]") // JSON array of purchased cosmetic ids
  currentDestination String?
  createdAt          DateTime          @default(now())
  achievements       UserAchievement[]
  transactions       CoinTransaction[]
}

model CoinTransaction {
  id        Int      @id @default(autoincrement())
  userId    Int
  amount    Int // signed: + earn, - spend
  reason    String // 'profile_complete' | 'achievement:<id>' | 'purchase:<itemId>' | ...
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Destination {
  id          Int     @id @default(autoincrement())
  name        String
  category    String
  image       String
  verified    Boolean @default(false)
  xpReward    Int     @default(100)
}

model Achievement {
  id          Int               @id @default(autoincrement())
  title       String
  description String
  xpReward    Int               @default(200)
  icon        String
  users       UserAchievement[]
}

model UserAchievement {
  userId        Int
  achievementId Int
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@id([userId, achievementId])
}
