// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int               @id @default(autoincrement())
  username           String            @unique
  email              String            @unique
  password           String
  city               String?
  region             String?
  name               String
  avatar             String            @default("/assets/avatar_default.svg")
  // Profile customization (bio, frame, background, badges, accent colour) as a
  // JSON blob — the same ProfileCustomization shape the profile wizard builds.
  // Stored server-side so other travelers can view this profile; null until the
  // user finishes (or edits) the wizard.
  profile            String?
  level              Int               @default(1)
  xp                 Int               @default(0)
  coins              Int               @default(0)
  rank               String            @default("mandrivnyk")
  unlockedItems      String            @default("[]") // JSON array of purchased cosmetic ids
  currentDestination String?
  // Live-GPS privacy toggle: when false, friends never see this user's dot.
  locationVisible    Boolean           @default(true)
  createdAt          DateTime          @default(now())
  achievements       UserAchievement[]
  transactions       CoinTransaction[]
  checkmarks         Checkmark[]
  visitedCells       VisitedCell[]
  wallPosts          WallPost[]

  sentFriendRequests     Friend[]  @relation("FriendSender")
  receivedFriendRequests Friend[]  @relation("FriendReceiver")
  sentMessages           Message[] @relation("MessageSender")
  receivedMessages       Message[] @relation("MessageReceiver")
  friendLabels           FriendLabel[]
  labelReactions         LabelReaction[]
}

// A friendship edge. One row per pair: sender is who initiated the request.
// SQLite has no enums, so status is a constrained string:
// PENDING | ACCEPTED | DECLINED.
model Friend {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())

  sender   User @relation("FriendSender", fields: [senderId], references: [id])
  receiver User @relation("FriendReceiver", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId, status])
}

// A direct chat message between two friends. readAt is null until the
// recipient opens the thread (read receipts).
model Message {
  id         Int       @id @default(autoincrement())
  senderId   Int
  receiverId Int
  text       String
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  sender   User @relation("MessageSender", fields: [senderId], references: [id])
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id])

  @@index([senderId, receiverId, id])
  @@index([receiverId, readAt])
}

model CoinTransaction {
  id        Int      @id @default(autoincrement())
  userId    Int
  amount    Int // signed: + earn, - spend
  reason    String // 'profile_complete' | 'achievement:<id>' | 'purchase:<itemId>' | ...
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Destination {
  id          Int     @id @default(autoincrement())
  name        String
  category    String
  image       String
  verified    Boolean @default(false)
  xpReward    Int     @default(100)
}

model Achievement {
  id          Int               @id @default(autoincrement())
  title       String
  description String
  xpReward    Int               @default(200)
  icon        String
  users       UserAchievement[]
}

model UserAchievement {
  userId        Int
  achievementId Int
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@id([userId, achievementId])
}

// A claimed reward for a code-defined achievement (see achievements.catalog.ts).
// `achievementKey` is the catalog key; `periodKey` is 'once' for permanent
// achievements and an ISO-week stamp (e.g. '2026-W29') for weekly ones, so a
// weekly achievement becomes claimable again each new week. The composite
// unique makes claiming idempotent per (user, achievement, period).
model AchievementClaim {
  id             Int      @id @default(autoincrement())
  userId         Int
  achievementKey String
  periodKey      String   @default("once")
  xpAwarded      Int
  coinsAwarded   Int
  claimedAt      DateTime @default(now())

  @@unique([userId, achievementKey, periodKey])
  @@index([userId])
}

// Admin account for the moderation panel. There is always exactly one super
// admin (isSuper) whose login/password come from env and are re-synced on boot;
// it cannot be deleted. Super admins and regular admins can create more admins.
model Admin {
  id        Int      @id @default(autoincrement())
  login     String   @unique
  password  String // bcrypt hash
  name      String   @default("Адміністратор")
  isSuper   Boolean  @default(false)
  createdBy String?
  createdAt DateTime @default(now())
}

// A place on the explore map. Covers both admin-curated entries and
// user-submitted ones that must pass AI moderation before going public.
model Place {
  id          Int    @id @default(autoincrement())
  name        String
  region      String
  category    String // nature | mountains | history | city | coast
  description String
  bestSeason  String @default("Будь-коли")

  // Geolocation is mandatory — real WGS84 coordinates.
  lat Float
  lng Float

  // JSON array of image data URLs. At least 2 are required on submission.
  photos String @default("[]")

  // Exploration difficulty, 1 (easy) – 4 (extreme). Drives the XP reward.
  difficulty Int @default(1)

  status      String  @default("pending") // pending | approved | rejected
  source      String  @default("user") // user | admin
  submittedBy String? // display name / email of the submitter

  // AI moderation verdict.
  aiDecision String? // approve | reject | review
  aiReason   String?
  aiScore    Float?

  createdAt  DateTime  @default(now())
  reviewedAt DateTime?

  checkmarks Checkmark[]

  @@index([status])
}

// A verified visit: the user came to a Place, photographed it, and the AI
// (or the offline fallback) confirmed the visit. XP/coins are awarded once.
model Checkmark {
  id             Int      @id @default(autoincrement())
  userId         Int
  placeId        Int
  photo          String // data URL of the photo the user took at the point
  distanceMeters Float // distance from the point when the photo was taken
  aiVerified     Boolean
  aiReason       String?
  xpAwarded      Int
  createdAt      DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  place Place @relation(fields: [placeId], references: [id])
  wallPosts WallPost[]

  // A place can be counted for a user only once.
  @@unique([userId, placeId])
}

// Territory exploration. Each row is one H3 cell the user has physically
// entered (see backend/src/exploration). We deliberately store only the H3
// cell id — never the raw GPS trace — so a lifetime of walking is a handful of
// short strings, not thousands of coordinates. The cell is captured at a fixed
// resolution (EXPLORE_RESOLUTION); its res-3 parent is used to detect entering
// a brand-new "region" for the milestone bonus, so no separate region table is
// needed.
model VisitedCell {
  id        Int      @id @default(autoincrement())
  userId    Int
  cellId    String // H3 index at EXPLORE_RESOLUTION
  visitedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  // A cell counts once per user — unlocking is idempotent.
  @@unique([userId, cellId])
  @@index([userId])
}

// A wall post is an entry in a traveler's activity feed: a verified place
// visit (opt-in, may include the checkmark photo), a newly unlocked
// exploration cell, or a newly opened region. Visible to the post's owner
// and their accepted friends (enforced in WallService, not at the schema
// level) — posts can carry visit photos, so they stay friends-only even
// though the profile itself is public.
model WallPost {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String // 'visit' | 'new_cell' | 'new_region'

  // Populated only when type === 'visit'.
  checkmarkId Int?
  placeId     Int?
  photo       String? // data URL, copied from the Checkmark only if the user opted in

  // Populated only when type === 'new_cell'. For 'new_region' rows this holds
  // the res-3 region id itself (not a fine cell) — no separate region table,
  // consistent with how VisitedCell already avoids one.
  cellId      String?

  xpAwarded   Int
  createdAt   DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id])
  checkmark Checkmark? @relation(fields: [checkmarkId], references: [id])

  @@index([userId, createdAt])
}

model FriendLabel {
  id           Int             @id @default(autoincrement())
  userId       Int
  name         String
  description  String
  lat          Float
  lng          Float
  photo        String?         // base64 Data URL, optional
  friendsOnly  Boolean         @default(true)
  isTemporary  Boolean         @default(false)
  expiresAt    DateTime?       // 24 hours from creation if temporary
  customParams String          @default("{}") // JSON string of custom key-value pairs
  createdAt    DateTime        @default(now())

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions    LabelReaction[]
}

model LabelReaction {
  id        Int         @id @default(autoincrement())
  labelId   Int
  userId    Int
  type      String      // 'LIKE' | 'DISLIKE'
  createdAt DateTime    @default(now())

  label     FriendLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([labelId, userId])
}


