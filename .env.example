# Database connection URL for PostgreSQL
DATABASE_URL="file:./dev.db"

# NestJS Application Port
PORT=3000

# Google Gemini API key for the AI travel advisor (ШІ-порадник).
# Get one at https://aistudio.google.com/apikey — leave empty to disable the advisor.
GEMINI_API_KEY=""
# Model used by the advisor (default: gemini-2.5-flash)
GEMINI_MODEL="gemini-3.1-flash-lite"

# Головний адміністратор панелі модерації (єдиний, фіксований акаунт).
# Змініть ці значення у продакшені на надійні.
ADMIN_LOGIN="admin"
ADMIN_PASSWORD="admin123"

# Google OAuth 2.0 (Sign in with Google). Get these at
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# SMTP (Mailtrap sandbox) — used to send account-verification emails.
# Get sandbox inbox credentials at https://mailtrap.io/
MAILTRAP_USER=""
MAILTRAP_PASS=""
MAILTRAP_HOST="sandbox.smtp.mailtrap.io"
MAILTRAP_PORT=2525

# Web Push (VAPID) keys for browser push notifications (messages, friend
# requests, walk reminders). Generate a pair with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Leave empty to disable push (the app degrades gracefully). VAPID_SUBJECT must
# be a mailto: or https: URL identifying your app.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:hello@absolutetravel.app"
